# /etc/hycert/api.env
# 複製並填入實際值：
#   sudo mkdir -p /etc/hycert
#   sudo cp api.env.example /etc/hycert/api.env
#   sudo chmod 600 /etc/hycert/api.env

SERVER_PORT=8082
SERVER_MODE=release
LOG_LEVEL=info
LOG_FILENAME=

# JWT (must match hyadmin-api's secret for cross-service token validation)
JWT_SECRET=CHANGE_ME_USE_STRONG_RANDOM_SECRET
JWT_EXPIRY_HOURS=24
