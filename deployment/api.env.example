# /etc/hycert/api.env
# 複製並填入實際值：
#   sudo mkdir -p /etc/hycert
#   sudo cp api.env.example /etc/hycert/api.env
#   sudo chmod 600 /etc/hycert/api.env

SERVER_PORT=8082
SERVER_MODE=release
LOG_LEVEL=info
LOG_FILENAME=

# Database (admin DB — stores TenantDBConfig for multi-tenant routing)
# 共用 /etc/hysp/db.env 的 DATABASE_DSN，或在此覆蓋
DATABASE_DSN=postgres://hysp:CHANGE_ME@10.30.0.69:5432/hysp_admin?sslmode=disable

# JWT (must match hyadmin-api's secret for cross-service token validation)
JWT_SECRET=CHANGE_ME_USE_STRONG_RANDOM_SECRET
JWT_EXPIRY_HOURS=24

# Tink (AEAD keyset JSON for encrypting private keys in DB)
# 需與 hyadmin-api 共用同一 keyset，或獨立一組
TINK_KEYSET=CHANGE_ME_PASTE_TINK_JSON_KEYSET
